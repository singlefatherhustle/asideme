{
  "name": "devlisten",
  "version": "3.1.0",
  "description": "DevListen v3 — full-featured live coding tutor",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "convert": "node png-to-md.js",
    "convert:week1": "node png-to-md.js slides/week1",
    "convert:week2": "node png-to-md.js slides/week2",
    "convert:week3": "node png-to-md.js slides/week3",
    "convert:all": "node png-to-md.js slides",
    "ingest": "node bulk-ingest.js",
    "ingest:slides": "node bulk-ingest.js slides",
    "ingest:week1": "node bulk-ingest.js slides/week1",
    "ingest:week2": "node bulk-ingest.js slides/week2",
    "ingest:week3": "node bulk-ingest.js slides/week3",
    "convert-and-ingest": "npm run convert:all && npm run ingest:slides",
    "stats": "node bulk-ingest.js --stats",
    "list": "node bulk-ingest.js --list"
  },
  "dependencies": {
    "@aws-sdk/client-transcribe-streaming": "^3.1015.0",
    "@deepgram/sdk": "^3.5.0",
    "@google-cloud/speech": "^7.3.0",
    "@sentry/node": "^10.54.0",
    "better-sqlite3": "^12.8.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^8.1.0",
    "ipaddr.js": "^2.4.0",
    "microsoft-cognitiveservices-speech-sdk": "^1.48.0",
    "openai": "^4.52.0",
    "pdfkit": "^0.13.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "resend": "^6.12.3",
    "stripe": "^22.1.1",
    "uuid": "^10.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
