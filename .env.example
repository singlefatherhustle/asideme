# ── Required ─────────────────────────────────────────────────────────────────
# At least ONE LLM provider key is required (Gemini is the default — see the
# "LLM providers" section below). ANTHROPIC is optional: used for BYOK, as a
# fallback, and to enable the native web-search step.
ANTHROPIC_API_KEY=

# Required in production. In dev, falls back to an insecure default.
# Generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-openssl-rand-hex-32

# ── Speech-to-Text (optional — Deepgram default; falls back if missing) ──────
DEEPGRAM_API_KEY=

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# Production: lock CORS to your domain. Dev: leave blank for wide-open.
CORS_ORIGIN=
# Public-facing URL — used in magic-link emails + Stripe redirect URLs.
APP_URL=http://localhost:3001

# ── Trial + abuse caps ───────────────────────────────────────────────────────
TRIAL_HOURS=48
DAILY_GENERATION_CAP=30
MAX_UPLOAD_BYTES=26214400

# ── Admin allowlist (for /api/ingest/reindex) — comma-separated emails ───────
ADMIN_EMAILS=

# ── Email verification ───────────────────────────────────────────────────────
# Production = true by default. Set to "true" in dev to test the magic-link
# flow; leave unset to skip verification gate while developing.
REQUIRE_EMAIL_VERIFICATION=
VERIFY_TOKEN_TTL_MIN=30

# ── Resend (transactional email — required if REQUIRE_EMAIL_VERIFICATION=true) ─
RESEND_API_KEY=
# Quote the value — the spaces and angle brackets otherwise trip some .env parsers.
EMAIL_FROM="AsideMe <noreply@asideme.app>"

# ── Stripe (billing) ─────────────────────────────────────────────────────────
# Get keys at https://dashboard.stripe.com/apikeys
# Webhook secret from `stripe listen --forward-to localhost:3001/api/stripe-webhook`
# Price IDs from your product/price configuration in Stripe.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
STRIPE_PRICE_ID_ANNUAL=

# ── Notion export (optional) ─────────────────────────────────────────────────
NOTION_API_KEY=
NOTION_DATABASE_ID=

# ── LLM providers + free-tier / BYOK ──────────────────────────────────────────
# Default AI is the free provider (Gemini); Anthropic is now optional (BYOK/fallback).
DEFAULT_LLM_PROVIDER=gemini
FALLBACK_LLM_PROVIDER=groq
# Free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Free key: https://console.groq.com/keys
GROQ_API_KEY=
# Optional per-provider model overrides:
# GEMINI_MODEL=gemini-2.5-flash
# GROQ_MODEL=llama-3.3-70b-versatile
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# OPENAI_MODEL=gpt-4o-mini

# Free-for-all: bypass the trial/subscription paywall (accounts + caps still apply).
FREE_FOR_ALL=true
# Daily generation caps: free-tier (owner's shared key) vs BYOK (user's own key/cost).
FREE_DAILY_GENERATION_CAP=15
# DAILY_GENERATION_CAP=30   (already documented above)

# Required to store user BYOK keys encrypted at rest (AES-256-GCM). 32+ random chars.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KEY_ENC_SECRET=

# ── Observability (optional, recommended in production) ──────────────────────
# Sentry error tracking — leave blank to disable.
SENTRY_DSN=
# pino log level: trace|debug|info|warn|error
LOG_LEVEL=info

# ── /metrics endpoint protection ─────────────────────────────────────────────
# Bearer token required to scrape /metrics. If unset, /metrics is hidden (404)
# in production. Generate: openssl rand -hex 32
METRICS_TOKEN=

# ── STT cost/abuse guards (WebSocket transcription) ──────────────────────────
# Close a transcription socket after this many seconds with no audio.
STT_IDLE_TIMEOUT_SEC=120
# Hard cap on a single transcription session, in minutes.
STT_MAX_SESSION_MIN=60

# ── Reverse proxy ────────────────────────────────────────────────────────────
# Trusted proxy hops in front of the app (Caddy/Nginx/Cloud LB = 1). Controls
# how req.ip is derived for rate limiting — set correctly or limiters misbehave.
TRUST_PROXY_HOPS=1

# ── Alternate STT providers (only if you change TRANSCRIPTION_PROVIDER) ───────
# TRANSCRIPTION_PROVIDER=deepgram  # deepgram|google|google-plugin|aws|azure|whisper|browser
# OPENAI_API_KEY=                  # whisper STT
# GOOGLE_APPLICATION_CREDENTIALS=  # path to GCP service-account JSON (google STT)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=eastus
